generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// 1. agents — агенты (CRM)
model Agent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String   @unique
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  passwordHash String?  @map("password_hash")
  role         String   @default("agent")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  leads              Lead[]
  beatMyPriceRequests BeatMyPriceRequest[]

  @@index([isActive])
  @@map("agents")
}

// 2. leads — главная таблица бизнеса
model Lead {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name    String
  email   String?
  phone   String
  message String?

  // Маршрут
  origin            String?
  destination       String?
  departDate        DateTime? @map("depart_date") @db.Date
  returnDate        DateTime? @map("return_date") @db.Date
  cabinClass        String?   @map("cabin_class")
  passengersAdults  Int       @default(1) @map("passengers_adults")
  passengersChildren Int      @default(0) @map("passengers_children")
  passengersInfants Int       @default(0) @map("passengers_infants")

  // Источник
  formLocation String? @map("form_location")
  abVariant    String? @map("ab_variant")
  source       String?
  sourceUrl    String? @map("source_url")

  // UTM
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")

  // CRM
  status     String   @default("new")
  agentId    String?  @map("agent_id") @db.Uuid
  agent      Agent?   @relation(fields: [agentId], references: [id])
  agentNotes String?  @map("agent_notes")
  quotedPrice Decimal? @map("quoted_price") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([abVariant])
  @@index([agentId])
  @@map("leads")
}

// 3. deals — акции и предложения
model Deal {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String   @unique
  origin          String
  originCode      String   @map("origin_code")
  destination     String
  destinationCode String   @map("destination_code")
  countryCode     String   @map("country_code")
  cabinClass      String   @map("cabin_class")
  publicFare      Decimal  @map("public_fare") @db.Decimal(10, 2)
  pfPrice         Decimal  @map("pf_price") @db.Decimal(10, 2)
  imageUrl        String?  @map("image_url")
  themeColor      String?  @map("theme_color")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  startsAt        DateTime? @map("starts_at") @db.Timestamptz
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isActive, sortOrder])
  @@map("deals")
}

// 4. destinations — направления
model Destination {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  city        String
  country     String
  countryCode String   @map("country_code")
  airportCode String   @map("airport_code")
  imageUrl    String?  @map("image_url")
  fromPrice   Decimal  @map("from_price") @db.Decimal(10, 2)
  region      String
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([region, isActive, sortOrder])
  @@map("destinations")
}

// 5. airlines — авиакомпании
model Airline {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String   @unique
  logoUrl       String?  @map("logo_url")
  imageUrl      String?  @map("image_url")
  featuredRoute String?  @map("featured_route")
  savingPercent Int?     @map("saving_percent")
  iataCode      String?  @map("iata_code")
  description   String?
  alliance      String?
  hubCity       String?  @map("hub_city")
  routeCodes    String[] @default([]) @map("route_codes")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isActive, sortOrder])
  @@map("airlines")
}

// 6. blog_posts — блог
model BlogPost {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String    @unique
  title        String
  excerpt      String?
  content      String?
  imageUrl     String?   @map("image_url")
  category     String?
  authorName   String?   @map("author_name")
  authorRole   String?   @map("author_role")
  authorAvatar String?   @map("author_avatar")
  readTime     String?   @map("read_time")
  isTrending   Boolean   @default(false) @map("is_trending")
  isPublished  Boolean   @default(false) @map("is_published")
  publishedAt  DateTime? @map("published_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isPublished, publishedAt(sort: Desc)])
  @@index([slug])
  @@map("blog_posts")
}

// 7. testimonials — отзывы
model Testimonial {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  role      String?
  location  String?
  rating    Int      @default(5)
  text      String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([isActive, sortOrder])
  @@map("testimonials")
}

// 8. beat_my_price_requests — запросы на сравнение цен
model BeatMyPriceRequest {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  origin          String?
  destination     String?
  cabinClass      String?  @map("cabin_class")
  competitorPrice Decimal? @map("competitor_price") @db.Decimal(10, 2)
  competitorUrl   String?  @map("competitor_url")
  screenshotUrl   String?  @map("screenshot_url")
  phone           String?
  email           String
  status          String   @default("new")
  ourPrice        Decimal? @map("our_price") @db.Decimal(10, 2)
  agentId         String?  @map("agent_id") @db.Uuid
  agent           Agent?   @relation(fields: [agentId], references: [id])
  agentNotes      String?  @map("agent_notes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([agentId])
  @@map("beat_my_price_requests")
}

// 9. site_settings — key-value конфигурация
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("site_settings")
}

// 10. ab_variant_views — уникальные просмотры A/B вариантов (по visitor + день)
model AbVariantView {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variant   String
  page      String   @default("search")
  visitorId String   @map("visitor_id")
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([visitorId, page, date])
  @@index([variant, page, date])
  @@map("ab_variant_views")
}
